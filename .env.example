# Expo app environment only.
# These values are read by the mobile app.
# AI provider secrets such as LOCAL_GEMMA_*, GROQ_*, and GEMINI_* belong in the Supabase
# Edge Function runtime, not here.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
EXPO_PUBLIC_AI_LISTING_ASSIST_ENABLED=true
