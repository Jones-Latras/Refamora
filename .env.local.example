# Hosted Expo app environment.
# Copy these values into `.env` or `.env.local` for a cloud Supabase project.
# Keep AI provider secrets such as `GROQ_*` in Supabase Edge Function secrets,
# not in the Expo app env file.

APP_ENV=development
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
EXPO_PUBLIC_AI_LISTING_ASSIST_ENABLED=true
