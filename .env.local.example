# Local Expo app environment for a local Supabase stack.
# Copy these values into `.env` or `.env.local` for local development.
#
# Replace `SUPABASE_ANON_KEY` with the anon key shown by your local Supabase
# stack when it starts.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
EXPO_PUBLIC_AI_LISTING_ASSIST_ENABLED=true
