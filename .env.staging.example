# Expo app environment for the staging build profile.
# Copy these values into `.env` or `.env.local` before running a staging build.
# Do not place AI provider secrets such as `GROQ_*` in this file.

APP_ENV=staging
SUPABASE_URL=https://your-staging-project-id.supabase.co
SUPABASE_ANON_KEY=your-staging-public-anon-key
EXPO_PUBLIC_AI_LISTING_ASSIST_ENABLED=true
