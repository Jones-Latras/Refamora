# Expo app environment for the production build profile.
# Copy these values into `.env` or `.env.local` before running a production build.
# Do not place AI provider secrets such as `GROQ_*` in this file.

APP_ENV=production
SUPABASE_URL=https://your-production-project-id.supabase.co
SUPABASE_ANON_KEY=your-production-public-anon-key
EXPO_PUBLIC_AI_LISTING_ASSIST_ENABLED=true
