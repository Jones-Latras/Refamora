# Local Supabase Edge Function environment for AI features.
# Copy to `supabase/functions/.env.local` when serving functions locally.
#
# This file is for the function runtime, not the Expo app.
# If your app still points to a remote Supabase project, these local values
# will not affect that remote project's functions.

LOCAL_GEMMA_ENABLED=true
LOCAL_GEMMA_BASE_URL=http://127.0.0.1:11434
LOCAL_GEMMA_MODEL=llama3.2:3b
LOCAL_GEMMA_TIMEOUT_MS=60000

GROQ_VISION_ENABLED=true
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_TIMEOUT_MS=20000

GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=20000

# Recommended setup:
# - Keep LOCAL_GEMMA_ENABLED=true for text-based AI tasks.
# - Set GROQ_VISION_ENABLED=true for photo analysis and photo moderation.
# - Keep GEMINI_ENABLED=false unless you still want Gemini as a separate text fallback.

AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_WINDOW_MINUTES=10
AI_RATE_LIMIT_MAX_REQUESTS=8
